# Used when running the service outside Docker (`cp .env.example .env` — see README).
# docker-compose.yml does NOT read this file: it hardcodes its own values for these same
# variables (VALKEY_HOST/MQTT_HOST need Docker-network hostnames here, not "localhost").
# If you're running via Docker, edit docker-compose.yml directly instead, e.g. to add a
# remote client's origin to CORS_ORIGINS.
VALKEY_HOST=valkey
VALKEY_PORT=6379
MQTT_HOST=mqtt
MQTT_PORT=1883
CORS_ORIGINS=http://localhost:8080,http://localhost:8081
PUBLIC_API_BASE_URL=https://localhost:8000
